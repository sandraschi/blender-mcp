{
  "productName": "Blender MCP",
  "version": "0.1.0",
  "identifier": "ai.fleet.blender-mcp",
  "build": {
    "frontendDist": "../webapp/frontend/dist",
    "devUrl": "http://localhost:10848",
    "beforeDevCommand": "npm --prefix ../webapp/frontend run dev"
  },
  "app": {
    "windows": [{
      "title": "Blender MCP",
      "width": 1200, "height": 800,
      "minWidth": 800, "minHeight": 600
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": ["binaries/blender-mcp-backend"]
  },
  "plugins": {
    "shell": { "open": true },
    "fs": { "requireLiteralLeadingDot": false },
    "process": { "all": true }
  }
}
