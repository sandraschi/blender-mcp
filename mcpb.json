{
  "name": "blender-mcp",
  "version": "1.0.0",
  "type": "server",
  "runtime": "python",
  "entry_point": "src/blender_mcp/server.py",
  "dependencies": [
    "fastmcp>=2.14.4,<3.0.0",
    "bpy>=4.0.0"
  ],
  "build": {
    "include": [
      "src/**/*",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "tests/",
      ".git/",
      "__pycache__/",
      "*.pyc",
      ".venv/",
      "dist/",
      "build/",
      "target/",
      "docs/",
      "scripts/",
      "mcpb-packaging/",
      "mcpb/",
      "target_wasm/"
    ]
  },
  "scripts": {
    "build": "mcpb build",
    "pack": "mcpb pack . dist/blender-mcp.mcpb",
    "test": "python -m pytest"
  }
}